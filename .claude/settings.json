{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(cat *.env*)",
      "Bash(cat .env*)",
      "Bash(grep * .env*)",
      "Bash(grep *.env*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(nano *.env*)",
      "Bash(vi *.env*)",
      "Bash(vim *.env*)",
      "Bash(xxd *.env*)",
      "Bash(od *.env*)",
      "Bash(strings *.env*)"
    ]
  }
}
